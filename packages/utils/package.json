{
  "name": "@dev-vault/utils",
  "version": "0.0.1-alpha.1",
  "description": "Helper functions and tools for my playground.",
  "main": "dist/index.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "prepare": "pnpm build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:ci": "vitest run --coverage",
    "docs": "typedoc --out docs",
    "docs:watch": "concurrently \"typedoc --out docs --watch\" \"http-server docs -o\""
  },
  "keywords": [
    "utilities",
    "typescript",
    "vitest",
    "monorepo"
  ],
  "license": "MIT",
  "devDependencies": {
    "@dev-vault/typedoc-plugin-vitest-examples": "workspace:^0.1.0-alpha",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^10.0.0",
    "http-server": "^14.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
