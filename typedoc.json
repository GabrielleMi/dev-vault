{
    "entryPoints": [
      "packages/*"
    ],
    "customCss": "docs-src/theme.css",
    "name": "Dev Vault",
    "entryPointStrategy": "packages",
    "includeVersion": false,
    "excludeExternals": true,
    "excludeInternal": true,
    "cleanOutputDir": true,
    "navigation": {
      "includeGroups": true,
      "includeFolders": false,
      "includeCategories": true
    },
    "categoryOrder": ["Packages", "*"],
    "defaultCategory": "Packages",
    "plugin": [
      "@GabrielleMi/typedoc-plugin-vitest-examples",
      "typedoc-plugin-mdn-links",
      "./docs-src/rename-modules.cjs"
    ]
}
