{
    "entryPoints": [
        "packages/*"
    ],
    "name": "Dev Vault",
    "entryPointStrategy": "packages",
    "includeVersion": false,
    "excludeExternals": true,
    "excludeInternal": true,
    "cleanOutputDir": true,
    "navigation": {
        "includeGroups": true,
        "includeFolders": true,
        "includeCategories": true
    },
    "categorizeByGroup": true,
    "plugin": [
        "@GabrielleMi/typedoc-plugin-vitest-examples"
    ]
}
