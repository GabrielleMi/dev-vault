{
  "name": "dev-vault",
  "version": "0.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "release": "pnpm build && changeset publish",
    "build": "pnpm --filter \"@GabrielleMi/*\" run build",
    "clean": "tsc -b --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench",
    "update": "pnpm up --i --latest -r",
    "docs:build": "typedoc",
    "docs:clean": "node -e \"const fs = require('fs'); ['docs', 'node_modules/.cache/typedoc'].forEach(p => fs.rmSync(p, { recursive: true, force: true }));\"",
    "docs:watch": "typedoc --entryPointStrategy expand --watch",
    "serve:docs": "browser-sync start --server docs --files \"docs\" --port 8080 --no-ui --no-notify",
    "dev:docs": "concurrently \"pnpm run docs:watch\" \"pnpm run serve:docs\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "browser-sync": "^3.0.4",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-jsdoc": "^63.0.13",
    "globals": "^17.7.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typedoc-plugin-merge-modules": "^7.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
