  "main": "index.js",
  "scripts": {
    "release": "pnpm build && changeset publish",
    "build": "pnpm --filter \"@dev-vault/*\" run build",
    "clean": "tsc -b --clean",
    "test": "pnpm -r test",
    "docs:plugin": "pnpm --filter @dev-vault/typedoc-plugin-vitest-examples docs:watch",
    "docs:utils": "pnpm --filter @dev-vault/utils docs:watch",
    "docs": "pnpm run build && typedoc --logLevel Verbose --plugin ./packages/typedoc-plugin-vitest-examples",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-merge-modules": "^7.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "@eslint/json": "^2.0.0"
  }
